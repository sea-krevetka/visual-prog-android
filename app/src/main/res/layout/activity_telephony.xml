<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <EditText
                android:id="@+id/etZmqHost"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="ZMQ Host (e.g., 127.0.0.1)" />

            <EditText
                android:id="@+id/etZmqPort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:ems="6"
                android:hint="2222" />

            <Button
                android:id="@+id/btnZmqToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable Send" />

            <Button
                android:id="@+id/btnZmqUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Update Endpoint" />
        
            <Button
                android:id="@+id/btnShowSent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Show Sent" />
        </LinearLayout>

        <TextView
        android:id="@+id/tvCellInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading cell info..."
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:lineSpacingExtra="4dp"
        android:paddingBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnStartService"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Start Background" />

            <Button
                android:id="@+id/btnStopService"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Stop Background" />
        </LinearLayout>

        <com.example.calc.ui.ImPlotSignalChartView
            android:id="@+id/chartSignal"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="8dp"
            android:background="#121212" />

    </LinearLayout>

</ScrollView>
